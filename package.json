{
  "name": "leak-scanner",
  "version": "1.0.0",
  "description": "API Key Leak Scanner - TypeScript rewrite",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "leak-scanner": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "tsx src/scanner.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "api-key",
    "leak-scanner",
    "github",
    "security"
  ],
  "license": "MIT",
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.4.2",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "nock": "^14.0.15",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
